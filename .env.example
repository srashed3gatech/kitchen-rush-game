# Kitchen Rush — example env. Copy to `.env` if you want to override defaults.
#
# MASTER_ENCRYPTION_KEY is NOT stored here. It lives at:
#   ~/.config/kitchen-rush/master.key
# (auto-generated on first server boot in dev — see docs/architecture.md §5).
# You may override its path with MASTER_KEY_PATH if needed.
#
# SESSION_SIGNING_SECRET auto-generates to this file on first boot in dev.
SESSION_SIGNING_SECRET=
NODE_ENV=development
PORT=4000
