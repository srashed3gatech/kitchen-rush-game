{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(./run.zsh:*)",
      "Bash(npm install)",
      "Bash(npm run build:*)",
      "Bash(npm run dev:*)",
      "Bash(npm run typecheck:*)",
      "Bash(npm run start:*)",
      "Bash(npm run test:*)",
      "Bash(npm test:*)",
      "Bash(npm --workspace*)",
      "Bash(npx tsc:*)",
      "Bash(npx vite:*)",
      "Bash(git status:*)",
      "Bash(git log:*)",
      "Bash(git diff:*)",
      "Bash(git show:*)",
      "Bash(git branch:*)",
      "Bash(git remote:*)",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(grep:*)",
      "Bash(rg:*)",
      "Bash(find:*)",
      "Bash(wc:*)",
      "Bash(file:*)",
      "Bash(du:*)",
      "Bash(df:*)",
      "Bash(curl -sf http://localhost:*)",
      "Bash(curl -s http://localhost:*)",
      "Bash(curl -sfI http://localhost:*)",
      "Bash(sqlite3 apps/server/data/*)",
      "Read(./*)",
      "Glob(./*)",
      "Grep(./*)"
    ]
  }
}
