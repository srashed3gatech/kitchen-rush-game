{
  "name": "@kitchen-rush/server",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch --conditions=development src/index.ts",
    "build": "tsc -p tsconfig.json && cp src/db/schema.sql dist/db/schema.sql",
    "start": "node dist/index.js",
    "seed": "tsx --conditions=development src/db/seed.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.27.0",
    "@kitchen-rush/shared": "*",
    "better-sqlite3": "^11.0.0",
    "cookie-parser": "^1.4.7",
    "express": "^4.19.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/cookie-parser": "^1.4.7",
    "@types/express": "^4.17.0",
    "@types/node": "^20.0.0",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0"
  }
}
