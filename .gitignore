# ── Dependencies ─────────────────────────────────────────────────────────
node_modules/
.pnpm-store/

# ── Build outputs ────────────────────────────────────────────────────────
dist/
build/
*.tsbuildinfo
.vite/

# ── Local environment / secrets ──────────────────────────────────────────
# .env holds SESSION_SIGNING_SECRET and (optionally) MASTER_ENCRYPTION_KEY.
# Each clone auto-generates its own — NEVER commit one.
.env
.env.local
.env.*.local
apps/*/.env

# Master encryption key (lives at ~/.config/kitchen-rush/master.key in dev,
# but if anyone places one in the repo by accident, keep it out).
master.key
*.pem
*.key

# ── Database (per-machine state) ─────────────────────────────────────────
*.sqlite
*.sqlite-journal
*.sqlite-wal
*.sqlite-shm
apps/server/data/*.sqlite*

# ── Logs ─────────────────────────────────────────────────────────────────
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── Editor / OS junk ─────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
*.swo

# ── Claude Code per-user state ──────────────────────────────────────────
# Keep .claude/launch.json (shareable preview config), drop the rest.
.claude/settings.local.json
.claude/projects/
.claude/memory/
.claude/sessions/

# ── Test / coverage ──────────────────────────────────────────────────────
coverage/
.nyc_output/

# ── macOS service artifacts (created by run.zsh service install) ────────
~$*
out.log
err.log

# ── Sandbox / temp ───────────────────────────────────────────────────────
sandbox/scratch*
tmp/
